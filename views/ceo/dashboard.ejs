<!DOCTYPE html>
<html>

<head>
    <%- include('../head') %>
        <title>CEO Dashboard</title>
        <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
        <style>
            .metric-card {
                border-left: 3px solid #7C4DFF;
            }
        </style>
</head>

<body>

    <div class="container-fluid">
        <div class="row position-sticky">

            <%- include('../sidebar') %>

                <main class="col-md-9 col-lg-10 p-4">
                    <div class="d-flex justify-content-between align-items-center">
                        <a href="javascript:history.back()">

                            <i class="bi bi-arrow-left"></i>

                        </a>
                        <div>
                            <p class="custom-card-header" style="font-size: 23px;">Hello, <%= user.full_name[0].toUpperCase() +
                                    user.full_name.slice(1) %>
                            </p>
                        </div>
                    </div>


                    <h3 class="mb-4">CEO Dashboard</h3>

                    <!-- Financial Cards -->

                    <div class="row g-4 mb-4">

                        <div class="col-md-3">
                            <div class="custom-card metric-card p-3">
                                <div>
                                    <h6 class="metric-title">Revenue</h6>
                                    <h4>PKR <%= Number(revenue).toLocaleString() %>
                                    </h4>
                                </div>
                            </div>
                        </div>

                        <div class="col-md-3">
                            <div class="custom-card metric-card p-3">
                                <div>
                                    <h6 class="metric-title">Expenses</h6>
                                    <h4>PKR <%= Number(expenses).toLocaleString() %>
                                    </h4>
                                </div>
                            </div>
                        </div>

                        <div class="col-md-3">
                            <div class="custom-card metric-card p-3">
                                <div>
                                    <h6 class="metric-title">Net Monthly Profit</h6>
                                    <h4>PKR <%= Number(profit).toLocaleString() %>
                                    </h4>
                                </div>
                            </div>
                        </div>

                        <div class="col-md-3">
                            <div class="metric-card custom-card p-3">
                                <div>
                                    <h6 class="metric-title">Profit Margin</h6>
                                    <h4>
                                        <%= revenue ? ((profit/revenue)*100).toFixed(1) : 0 %>%
                                    </h4>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- KPI metric-card custom-cards -->

                    <div class="row g-4 mb-4">

                        <div class="col-md-3">
                            <div class="metric-card custom-card p-3 ">
                                <div>
                                    <h6 class="metric-title">Customers</h6>

                                    <h4>
                                        <%= customers %>
                                    </h4>
                                </div>
                            </div>
                        </div>

                        <div class="col-md-3">
                            <div class="metric-card custom-card p-3">
                                <div>
                                    <h6 class="metric-title">Vendors</h6>

                                    <h4>
                                        <%= vendors %>
                                    </h4>
                                </div>
                            </div>
                        </div>

                        <div class="col-md-3">
                            <div class="metric-card custom-card p-3 ">

                                <div>
                                    <h6 class="metric-title">Products</h6>
                                    <h4>
                                        <%= products %>
                                    </h4>
                                </div>
                            </div>
                        </div>

                        <div class="col-md-3">
                            <div class="metric-card custom-card p-3 ">
                                <div>
                                    <h6 class="metric-title">Orders</h6>


                                    <h4>
                                        <%= orders %>
                                    </h4>
                                </div>
                            </div>
                        </div>

                    </div>

                    <!-- Risk Indicators -->

                    <div class="row g-4 mb-4">

                        <div class="col-md-3">
                            <div class="metric-card custom-card p-3">
                                <div>
                                    <h6 class="metric-title">Receivables</h6>

                                    <h4>PKR <%= Number(receivables).toLocaleString() %>
                                    </h4>
                                </div>
                            </div>
                        </div>

                        <div class="col-md-3">
                            <div class="metric-card custom-card p-3">

                                <div>
                                    <h6 class="metric-title">Payables</h6>

                                    <h4>PKR <%= Number(payables).toLocaleString() %>
                                    </h4>
                                </div>
                            </div>
                        </div>

                        <div class="col-md-3">
                            <div class="metric-card custom-card p-3">

                                <div>
                                    <h6 class="metric-title">Low Stock</h6>

                                    <h4>
                                        <%= lowStock %>
                                    </h4>
                                </div>
                            </div>
                        </div>

                        <div class="col-md-3">
                            <div class="metric-card custom-card p-3">
                                <div>
                                    <h6 class="metric-title">Pending complaints</h6>

                                    <h4>
                                        <%= complaints %>
                                    </h4>
                                </div>
                            </div>
                        </div>

                    </div>

                    <!-- Sales vs Purchases Chart -->
                    <div class="row mb-4">

                        <!-- Sales vs Purchases Chart -->
                        <div class="col-md-6">
                            <div class="custom-card p-4 mb-4">
                                <h5>Sales vs Purchases</h5>
                                <div style="height: 300px; width: 100%;">
                                    <canvas id="salesChart"></canvas>
                                </div>
                            </div>
                        </div>

                        <!-- Profits Chart -->
                        <div class="col-md-6">
                            <div class="custom-card p-4 mb-4">
                                <h5>Profits</h5>
                                <div style="height: 300px; width: 100%;">
                                    <canvas id="profitChart" height="150"></canvas>
                                </div>
                            </div>
                        </div>

                    </div>

                    <!-- Top Tables -->

                    <div class="row">

                        <div class="col-md-4 mb-3">
                            <div class="custom-card p-3">
                                <h6>Top Customers</h6>
                                <table class="table">
                                    <% topCustomers.forEach(c=>{ %>
                                        <tr>
                                            <td>
                                                <%= c.name %>
                                            </td>
                                            <td>
                                                <%= Number(c.revenue).toLocaleString() %>
                                            </td>
                                        </tr>
                                        <% }) %>
                                </table>
                            </div>
                        </div>

                        <div class="col-md-4 mb-3">
                            <div class="custom-card p-3">
                                <h6>Top Selling Products</h6>
                                <table class="table">
                                    <% topProducts.forEach(p=>{ %>
                                        <tr>
                                            <td>
                                                <%= p.name %>
                                            </td>
                                            <td>
                                                <%= p.sold %>
                                            </td>
                                        </tr>
                                        <% }) %>
                                </table>
                            </div>
                        </div>

                        <div class="col-md-4 mb-3">
                            <div class="custom-card p-3">
                                <h6>Top Vendors</h6>
                                <table class="table">
                                    <% topVendors.forEach(v=>{ %>
                                        <tr>
                                            <td>
                                                <%= v.name %>
                                            </td>
                                            <td>
                                                <%= Number(v.purchases).toLocaleString() %>
                                            </td>
                                        </tr>
                                        <% }) %>
                                </table>
                            </div>
                        </div>

                    </div>
                </main>
        </div>
    </div>
    <script>
        document.addEventListener('DOMContentLoaded', async () => {

            const userRole = "<%= user.role_id || '' %>";
            if (userRole !== '1') return;

            const res = await fetch("/procure/manager/new-updates");
            const data = await res.json();
            const name = <%- JSON.stringify(user.full_name) %>;

            const synth = window.speechSynthesis;
            let selectedVoice;

            function loadVoices() {
                const voices = synth.getVoices();
                selectedVoice = voices.find(v => v.lang === "en-US") || voices[0];
            }

            loadVoices();
            speechSynthesis.onvoiceschanged = loadVoices;

            function speak(text, callback) {
                const speech = new SpeechSynthesisUtterance(text);
                speech.voice = selectedVoice;
                speech.lang = "en-US";
                speech.rate = 1;

                if (callback) speech.onend = callback;

                synth.speak(speech);
            }

            setTimeout(() => {

                speak(
                    `Hello ${name}. ${data.message}.`
                );

            }, 1000);


            function listenForResponse() {

                const SpeechRecognition = window.SpeechRecognition || window.webkitSpeechRecognition;
                if (!SpeechRecognition) return;

                const recognition = new SpeechRecognition();
                recognition.lang = 'en-US';

                recognition.onresult = (event) => {

                    const result = event.results[0][0].transcript.toLowerCase();
                    recognition.stop();

                    if (result.includes("yes")) {

                        speak(data.message);

                    } else {

                        speak("Okay. Let me know if you need anything.");

                    }

                };

                recognition.start();
            }

        });
    </script>
    <script>

        const chartData = <%- JSON.stringify(chart) %>;

        const labels = chartData.map(x => x.month);
        const sales = chartData.map(x => x.sales);
        const purchases = chartData.map(x => x.purchases);

        new Chart(document.getElementById("salesChart"), {
            type: "bar",
            data: {
                labels: labels,
                datasets: [
                    {
                        label: "Sales",
                        data: sales
                    },
                    {
                        label: "Purchases",
                        data: purchases
                    }
                ]
            }
        });

        const profitData = <%- JSON.stringify(profits) %>;
        const profitsValues = profitData.map(x => x.profit);

        new Chart(document.getElementById("profitChart"), {
            type: "line",
            data: {
                labels: labels,
                datasets: [{
                    label: "Profit",
                    data: profitsValues,
                    fill: true, // fill under the line
                    borderColor: "#7C4DFF",
                    backgroundColor: "#7C4DFF26",
                    tension: 0.3 // smooth curve
                }]
            },
            options: {
                responsive: true,
                plugins: { legend: { position: "top" } },
                scales: {
                    y: { beginAtZero: true },
                    x: { ticks: { maxRotation: 0 } }
                }
            }
        });
    </script>
</body>

</html>