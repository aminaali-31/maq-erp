<!DOCTYPE html>
<html lang="en">
<head>

    <%- include('../head') %>

    <title>Published Quotations</title>

    <style>

        body{
            background:#e3eff7;
        }

        .quote-card{
            border:none;
            border-radius:12px;
            transition:0.3s;
            height:100%;
            border-left: 5px solid #0d6efd;
        }

        .quote-card:hover{
            transform:translateY(-5px);
            box-shadow:0 10px 25px rgba(0,0,0,0.1);
        }

        .quote-text{
            font-size:1.1rem;
            color:#333;
        }

        .quote-author{
            font-weight:600;
            color:#2b035c;
        }
    </style>

</head>

<body>

<div class="container py-5">

    <h2 class="mb-4 text-center quote-author">
        Quotations
    </h2>

    <div class="row g-4">

        <% quotes.forEach(q => { %>

        <div class="col-md-4">

            <div class="card shadow-sm  h-100 quote-card">

                <div class="card-body">

                    <div class="d-flex justify-content-between mb-2">
                        <span class="badge bg-primary mb-2">
                            Quote #<%= q.id %>
                        </span>

                        <small class="text-muted">
                            <%= new Date(q.date).toLocaleDateString() %>
                        </small>
                    </div>
                    <h5 class="mb-3 quote-text">
                       Title: <%= q.title %>
                    </h5>

                    <h6 class="fw-bold">
                        Rs <%= q.grand_total %>
                    </h6>

                    <div class="mt-3 d-grid">
                        <a href="/sales/quotes/<%= q.id %>" class="btn btn-outline-primary btn-sm">
                            View Quotation
                        </a>
                    </div>

                </div>

            </div>

        </div>

        <% }) %>

    </div>

</div>
</div>

</body>
</html>