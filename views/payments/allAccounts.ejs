<!DOCTYPE html>
<html lang="en">

<head>
    <%- include('../head') %>
        <title>All accounts</title>
        <meta http-equiv="refresh" content="5">
</head>

<body>
    <div class="container fluid">
        <div class="row position-sticky">
            <%- include('../sidebar') %>
                <main class="col-md-9 col-lg-10 p-4">
                    <a href="javascript:history.back()">
                        <i class="bi bi-arrow-left"></i>
                    </a>
                    <div class="container mt-4">

                        <h3 class="mb-4 fw-bold">All Accounts</h3>
                        <a href="/accounts/add" class="btn btn-outline-primary mb-3">Add account</a>
                        <div class="row mb-3 align-items-end">

                            <!-- Search -->
                            <div class="col-md-4">
                                <label class="form-label">Search</label>
                                <input type="text" id="accountSearch" class="form-control"
                                    placeholder="Search accounts...">
                            </div>

                            <!-- Status Filter -->
                            <div class="col-md-3">
                                <label class="form-label">Status</label>
                                <select id="statusFilter" class="form-select">
                                    <option value="">All</option>
                                    <option value="active">Active</option>
                                    <option value="inactive">Inactive</option>
                                </select>
                            </div>

                            <!-- Account Type Filter -->
                            <div class="col-md-3">
                                <label class="form-label">Account Type</label>
                                <select id="typeFilter" class="form-select">
                                    <option value="">All</option>
                                    <option value="asset">Asset</option>
                                    <option value="liability">Liability</option>
                                    <option value="expense">Expense</option>
                                    <option value="income">Income</option>
                                    <option value="equity">Equity</option>
                                </select>
                            </div>

                            <!-- Clear Filters -->
                            <div class="col-md-2">
                                <button class="btn btn-outline-secondary w-100" id="clearFilters" type="button">
                                    Clear
                                </button>
                            </div>

                        </div>
                        <div class="row">

                            <% accounts.forEach(a=>{ %>

                                <% let balance=Number(a.balance) || 0; let balanceClass="text-secondary" ; if(balance>
                                    0) balanceClass = "text-success";
                                    else if(balance < 0) balanceClass="text-danger" ; %>

                                        <div class="col-xl-4 col-lg-6 mb-4 account-card" data-name="<%= a.name %>"
                                            data-type="<%= a.type %>" data-status="<%= a.status %>">

                                            <div class="card border-0 shadow-sm h-100">

                                                <div class="card-body">

                                                    <!-- Account Header -->
                                                    <div class="d-flex justify-content-between align-items-center mb-3">
                                                        <% if (a.name==='expense' ) { %>
                                                            <h5 class="fw-semibold mb-0">Office Expense</h5>
                                                            <% } else { %>
                                                                <h5 class="fw-semibold mb-0">
                                                                    <%= a.name %>
                                                                </h5>
                                                                <% } %>
                                                                    <span
                                                                        class="badge bg-light text-dark text-capitalize">
                                                                        <%= a.type %>
                                                                    </span>

                                                    </div>

                                                    <hr>

                                                    <!-- Debit Credit Row -->
                                                    <div class="d-flex justify-content-between small mb-2">
                                                        <span class="text-muted">Total Debit</span>
                                                        <span class="fw-semibold">
                                                            <%= Number(a.total_debit || 0).toLocaleString() %>
                                                        </span>
                                                    </div>

                                                    <div class="d-flex justify-content-between small mb-2">
                                                        <span class="text-muted">Total Credit</span>
                                                        <span class="fw-semibold">
                                                            <%= Number(a.total_credit || 0).toLocaleString() %>
                                                        </span>
                                                    </div>

                                                    <hr>

                                                    <!-- Balance Display -->
                                                    <div class="d-flex justify-content-between align-items-center">

                                                        <span class="text-muted">Balance</span>

                                                        <span class="fs-5 fw-bold <%= balanceClass %>">
                                                            <%= balance.toLocaleString() %>
                                                        </span>

                                                    </div>

                                                    <!-- Ledger Button -->
                                                    <div class="mt-3 text-end">
                                                        <a href="/accounts/ledger/<%= a.id %>"
                                                            class="btn btn-sm btn-outline-primary">
                                                            View Ledger
                                                        </a>
                                                    </div>

                                                </div>
                                            </div>
                                        </div>

                                        <% }) %>

                                            <% let receivable=Number(rec.balance) || 0; let recClass="text-secondary" ;
                                                if(receivable>
                                                0) recClass = "text-success";
                                                else if(receivable < 0) recClass="text-danger" ; %>

                                                    <div class="col-xl-4 col-lg-6 mb-4">

                                                        <div class="card border-0 shadow-sm h-100">

                                                            <div class="card-body">

                                                                <!-- Account Header -->
                                                                <div
                                                                    class="d-flex justify-content-between align-items-center mb-3">

                                                                    <h5 class="fw-semibold mb-0">
                                                                        Receivable
                                                                    </h5>

                                                                    <span
                                                                        class="badge bg-light text-dark text-capitalize">
                                                                        asset
                                                                    </span>

                                                                </div>

                                                                <hr>

                                                                <!-- Debit Credit Row -->
                                                                <div class="d-flex justify-content-between small mb-2">
                                                                    <span class="text-muted">Total Debit</span>
                                                                    <span class="fw-semibold">
                                                                        <%= Number(rec.total_debit ||
                                                                            0).toLocaleString() %>
                                                                    </span>
                                                                </div>

                                                                <div class="d-flex justify-content-between small mb-2">
                                                                    <span class="text-muted">Total Credit</span>
                                                                    <span class="fw-semibold">
                                                                        <%= Number(rec.total_credit ||
                                                                            0).toLocaleString() %>
                                                                    </span>
                                                                </div>

                                                                <hr>

                                                                <!-- Balance Display -->
                                                                <div
                                                                    class="d-flex justify-content-between align-items-center">

                                                                    <span class="text-muted">Balance</span>

                                                                    <span class="fs-5 fw-bold <%= recClass %>">
                                                                        <%= receivable.toLocaleString() %>
                                                                    </span>

                                                                </div>

                                                                <!-- Ledger Button -->
                                                                <div class="mt-3 text-end">
                                                                    <a href="/accounts/receivables"
                                                                        class="btn btn-sm btn-outline-primary">
                                                                        View Ledger
                                                                    </a>
                                                                </div>

                                                            </div>
                                                        </div>
                                                    </div>

                                                    <% let payable=Number(pay.balance) || 0; let
                                                        payClass="text-secondary" ; if(payable>
                                                        0) payClass = "text-success";
                                                        else if(payable < 0) payClass="text-danger" ; %>

                                                            <div class="col-xl-4 col-lg-6 mb-4">

                                                                <div class="card border-0 shadow-sm h-100">

                                                                    <div class="card-body">

                                                                        <!-- Account Header -->
                                                                        <div
                                                                            class="d-flex justify-content-between align-items-center mb-3">

                                                                            <h5 class="fw-semibold mb-0">
                                                                                Payables
                                                                            </h5>

                                                                            <span
                                                                                class="badge bg-light text-dark text-capitalize">
                                                                                liability
                                                                            </span>

                                                                        </div>

                                                                        <hr>

                                                                        <!-- Debit Credit Row -->
                                                                        <div
                                                                            class="d-flex justify-content-between small mb-2">
                                                                            <span class="text-muted">Total Debit</span>
                                                                            <span class="fw-semibold">
                                                                                <%= Number(pay.total_debit ||
                                                                                    0).toLocaleString() %>
                                                                            </span>
                                                                        </div>

                                                                        <div
                                                                            class="d-flex justify-content-between small mb-2">
                                                                            <span class="text-muted">Total Credit</span>
                                                                            <span class="fw-semibold">
                                                                                <%= Number(pay.total_credit ||
                                                                                    0).toLocaleString() %>
                                                                            </span>
                                                                        </div>

                                                                        <hr>

                                                                        <!-- Balance Display -->
                                                                        <div
                                                                            class="d-flex justify-content-between align-items-center">

                                                                            <span class="text-muted">Balance</span>

                                                                            <span class="fs-5 fw-bold <%= payClass %>">
                                                                                <%= payable.toLocaleString() %>
                                                                            </span>

                                                                        </div>

                                                                        <!-- Ledger Button -->
                                                                        <div class="mt-3 text-end">
                                                                            <a href="/accounts/payables"
                                                                                class="btn btn-sm btn-outline-primary">
                                                                                View Ledger
                                                                            </a>
                                                                        </div>

                                                                    </div>
                                                                </div>
                                                            </div>

                        </div>
                    </div>
                </main>
        </div>
    </div>
    <script>
        const searchInput = document.getElementById('accountSearch');
        const statusFilter = document.getElementById('statusFilter');
        const typeFilter = document.getElementById('typeFilter');
        const clearBtn = document.getElementById('clearFilters');

        function filterAccounts() {

            const search = searchInput.value.toLowerCase();
            const status = statusFilter.value.toLowerCase().trim();
            const type = typeFilter.value;

            const cards = document.querySelectorAll('.account-card');

            cards.forEach(card => {

                const name = card.dataset.name.toLowerCase();
                const cardStatus = card.dataset.status.toLowerCase().trim();
                const cardType = card.dataset.type;

                let show = true;

                // Search filter
                if (search && !name.includes(search)) {
                    show = false;
                }

                // Status filter
                if (status && cardStatus !== status) {
                    show = false;
                }

                // Type filter
                if (type && cardType !== type) {
                    show = false;
                }

                card.style.display = show ? '' : 'none';

            });

        }

        searchInput.addEventListener('input', filterAccounts);
        statusFilter.addEventListener('change', filterAccounts);
        typeFilter.addEventListener('change', filterAccounts);

        clearBtn.addEventListener('click', () => {
            searchInput.value = '';
            statusFilter.value = '';
            typeFilter.value = '';
            filterAccounts();
        });
    </script>
</body>

</html>