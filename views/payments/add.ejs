<!DOCTYPE html>
<html lang="en">

<head>
    <%- include('../head') %>
        <title>Document</title>
</head>

<body>
    <div class="container fluid">
        <div class="row position-sticky">
            <%- include('../sidebar') %>
                <main class="col-md-9 col-lg-10 p-4">
                    <div class="container mt-4">

                        <h3>Add Payment</h3>

                        <form method="POST" action="/payments/add">

                            <div class="row">
                                <% if (success) { %>
                                    <div class="alert alert-success">
                                        <%= success %>
                                    </div>
                                    <% } %>

                                        <% if (error) { %>
                                            <div class="alert alert-danger">
                                                <%= error %>
                                            </div>
                                            <% } %>
                                                <div class="col-md-3 mb-3">
                                                    <label>Payment Type</label>
                                                    <select id="paymentType" name="payment_type" class="form-control"
                                                        required>
                                                        <option value="">Select</option>
                                                        <option value="sale">Sale</option>
                                                        <option value="purchase">Purchase</option>
                                                        <option value="expense">Expense</option>
                                                    </select>
                                                </div>


                                                <div class="col-md-4 mb-3" id="referenceBox" style="display:none">
                                                    <label>Reference</label>
                                                    <select id="referenceId" name="reference_id" class="form-control">
                                                        <option value="">Select Reference</option>
                                                    </select>

                                                </div>

                                                <div class="col-md-3 mb-3">
                                                    <label>Account</label>
                                                    <select name="account_id" class="form-control">

                                                        <% accounts.forEach(a=>{ %>
                                                            <option value="<%= a.id %>">
                                                                <%= a.name %>
                                                            </option>
                                                            <% }) %>

                                                    </select>
                                                </div>


                                                <div class="col-md-2 mb-3">
                                                    <label>Amount</label>
                                                    <input type="number" name="amount" class="form-control">
                                                </div>

                                                <div class="col-md-3 mb-3">
                                                    <label>Date</label>
                                                    <input type="date" name="payment_date" class="form-control">
                                                </div>

                                                <div class="col-md-6 mb-3">
                                                    <label>Notes</label>
                                                    <textarea name="notes" class="form-control"></textarea>
                                                </div>

                            </div>

                            <button class="btn btn-primary">Save Payment</button>

                        </form>

                    </div>
                    <script>

                document.addEventListener("DOMContentLoaded", function(){

                    const saleOrders = <%- JSON.stringify(sales || []) %>;
                    const purchaseOrders = <%- JSON.stringify(purchases || []) %>;

                    const paymentType = document.getElementById('paymentType');
                    const referenceBox = document.getElementById('referenceBox');
                    const referenceId = document.getElementById('referenceId');

                    if(!paymentType) return;

                    paymentType.addEventListener('change', function(){

                        let type = this.value;

                        referenceId.innerHTML = '<option value="">Select Reference</option>';

                        let data = [];

                        if(type === 'sale'){
                            data = saleOrders;
                            referenceBox.style.display = 'block';
                        }
                        else if(type === 'purchase'){
                            data = purchaseOrders;
                            referenceBox.style.display = 'block';
                        }
                        else{
                            referenceBox.style.display = 'none';
                            return;
                        }

                        data.forEach(item=>{
                            referenceId.innerHTML +=
                            `<option value="${item.id}">
                                ${type === 'sale' ? 'SO-' : 'PO-'}${item.id}
                            </option>`;
                        });

                    });

                });

                </script>
                </main>
        </div>
    </div>
</body>

</html>