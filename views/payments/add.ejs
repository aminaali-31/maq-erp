<!DOCTYPE html>
<html lang="en">

<head>
    <%- include('../head') %>
        <title>Document</title>
</head>

<body>
    <div class="container fluid">
        <div class="row position-sticky">
            <%- include('../sidebar') %>
                <main class="col-md-9 col-lg-10 p-4">
                    <div class="container mt-4">

                        <h3>Add Payment</h3>
                        <form method="POST" action="/payments/add">

                            <div class="row">
                                <% if (success) { %>
                                    <div class="alert alert-success w-100">
                                        <%= success %>
                                    </div>
                                    <% } %>

                                        <% if (error) { %>
                                            <div class="alert alert-danger w-100">
                                                <%= error %>
                                            </div>
                                            <% } %>

                                                <!-- Payment Type -->
                                                <div class="col-md-3 mb-3">
                                                    <label>Payment Type</label>
                                                    <select id="paymentType" name="payment_type" class="form-control"
                                                        required>
                                                        <option value="">Select</option>
                                                        <option value="sale">Sale</option>
                                                        <option value="purchase">Purchase</option>
                                                        <option value="expense">Expense</option>
                                                    </select>
                                                </div>
                
                                                <div class="col-md-3 mb-3">
                                                <label>From Account</label>
                                                <select name="from_account_id" class="form-control">
                                                <% accounts.forEach(a=>{ %>
                                                    <option value="<%= a.id %>"><%= a.name %></option>
                                                <% }) %>
                                                </select>
                                                </div>
                                                <div class="col-md-3 mb-3">
                                                <label>To Account</label>
                                                <select name="to_account_id" class="form-control">
                                                <% accounts.forEach(a=>{ %>
                                                    <option value="<%= a.id %>"><%= a.name %></option>
                                                <% }) %>
                                                </select>
                                                </div>
                                                <!-- Amount -->
                                                <div class="col-md-3 mb-3">
                                                    <label>Amount</label>
                                                    <input type="number" step="0.01" name="amount" class="form-control"
                                                        required>
                                                </div>

                                                <!-- Payment Date -->
                                                <div class="col-md-3 mb-3">
                                                    <label>Date</label>
                                                    <input type="date" name="payment_date" class="form-control"
                                                        value="<%= new Date().toISOString().split('T')[0] %>" required>
                                                </div>

                                                <!-- Notes -->
                                                <div class="col-md-6 mb-3">
                                                    <label>Notes</label>
                                                    <textarea name="notes" class="form-control"
                                                        placeholder="Optional description"></textarea>
                                                </div>

                            </div>

                            <button class="btn btn-primary">Save Payment</button>
                        </form>


                    </div>
                </main>
        </div>
    </div>
</body>

</html>