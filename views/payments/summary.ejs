<!DOCTYPE html>
<html lang="en">

<head>
    <%- include('../head') %>
        <title>Document</title>
</head>

<body>
    <div class="container fluid">
        <div class="row position-sticky">
            <%- include('../sidebar') %>
                <main class="col-md-9 col-lg-10 p-4">
                    <div class="container mt-4">

                        <h3 class="mb-4 fw-bold">Account Summary Dashboard</h3>

                        <div class="row">

                            <% accounts.forEach(a=>{ %>

                                <% let balance=Number(a.balance) || 0; let balanceClass="text-secondary" ; if(balance>
                                    0) balanceClass = "text-success";
                                    else if(balance < 0) balanceClass="text-danger" ; %>

                                        <div class="col-xl-4 col-lg-6 mb-4">

                                            <div class="card border-0 shadow-sm h-100">

                                                <div class="card-body">

                                                    <!-- Account Header -->
                                                    <div class="d-flex justify-content-between align-items-center mb-3">

                                                        <h5 class="fw-semibold mb-0">
                                                            <%= a.name %>
                                                        </h5>

                                                        <span class="badge bg-light text-dark text-capitalize">
                                                            <%= a.type %>
                                                        </span>

                                                    </div>

                                                    <hr>

                                                    <!-- Debit Credit Row -->
                                                    <div class="d-flex justify-content-between small mb-2">
                                                        <span class="text-muted">Total Debit</span>
                                                        <span class="fw-semibold">
                                                            <%= Number(a.total_debit || 0).toLocaleString() %>
                                                        </span>
                                                    </div>

                                                    <div class="d-flex justify-content-between small mb-2">
                                                        <span class="text-muted">Total Credit</span>
                                                        <span class="fw-semibold">
                                                            <%= Number(a.total_credit || 0).toLocaleString() %>
                                                        </span>
                                                    </div>

                                                    <hr>

                                                    <!-- Balance Display -->
                                                    <div class="d-flex justify-content-between align-items-center">

                                                        <span class="text-muted">Balance</span>

                                                        <span class="fs-5 fw-bold <%= balanceClass %>">
                                                            <%= balance.toLocaleString() %>
                                                        </span>

                                                    </div>

                                                    <!-- Ledger Button -->
                                                    <div class="mt-3 text-end">
                                                        <a href="/accounts/ledger/<%= a.id %>"
                                                            class="btn btn-sm btn-outline-primary">
                                                            View Ledger
                                                        </a>
                                                    </div>

                                                </div>
                                            </div>
                                        </div>

                                        <% }) %>

                        </div>
                    </div>
                </main>
        </div>
    </div>
</body>

</html>