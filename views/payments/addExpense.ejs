<!DOCTYPE html>
<html lang="en">

<head>
    <%- include('../head') %>
        <title>Add an Expense</title>
</head>

<body>
    <div class="container fluid">
        <div class="row position-sticky">
            <%- include('../sidebar') %>
                <main class="col-md-9 col-lg-10 p-4">
                    <a href="javascript:history.back()">
                        <i class="bi bi-arrow-left"></i>
                    </a>
                    <div class="container mt-4">
                        <h3 class="mb-4">Add Expense</h3>

                        <!-- Success Message -->
                        <% if (success) { %>
                            <div class="alert alert-success">
                                <%= success %>
                            </div>
                            <% } %>

                                <!-- Error Message -->
                                <% if (error) { %>
                                    <div class="alert alert-danger">
                                        <%= error %>
                                    </div>
                                    <% } %>

                                        <form action="/accounts/expenses/add" method="POST">

                                            <!-- Title -->
                                            <div class="mb-3">
                                                <label class="form-label">Expense Title</label>
                                                <input type="text" name="title" class="form-control" required>
                                            </div>
                                            <div class="mb-3">
                                                <label for="type" class="form-label">Type</label>
                                                <select name="type" id="type" class="form-control">
                                                    <option value="order">Order Expense</option>
                                                    <option value="office">Office Expense</option>
                                                </select>
                                            </div>
                                            <div class="mb-3" id="order_id">
                                                <label for="order" class="form-label">Order Reference</label>
                                                <select name="order_id" class="form-control">
                                                    <% orders.forEach(o=> { %>
                                                        <option value="<%= o.id %>">Sale order #<%= o.id %>| Total Cost <%=
                                                                    o.total_amount %> | Name <%= o.customer_name %>
                                                        </option>
                                                        <% }) %>
                                                </select>
                                            </div>
                                            <div class="mb-3" id="item_id">
                                                <label for="item" class="form-label">Item Reference</label>
                                                <select name="item_id" class="form-control" id="itemSelect">
                                                </select>
                                            </div>
                                            <!-- Amount -->
                                            <div class="mb-3">
                                                <label class="form-label">Amount</label>
                                                <input type="number" step="0.01" name="amount" class="form-control"
                                                    required>
                                            </div>
                                            <div class="mb-3">
                                                <label for="account" class="form-label">Payment Account</label>
                                                <select name="account" class="form-control">
                                                    <% accounts.forEach(a=> { %>
                                                        <option value="<%= a.id %>">
                                                            <%= a.name %>
                                                        </option>
                                                        <% }) %>
                                                </select>
                                            </div>

                                            <!-- Expense Date -->
                                            <div class="mb-3">
                                                <label class="form-label">Expense Date</label>
                                                <input type="date" name="expense_date" class="form-control" required>
                                            </div>


                                            <button class="btn btn-primary">
                                                Add Expense
                                            </button>

                                        </form>
                    </div>
                </main>
        </div>
    </div>
    <script>
        document.addEventListener("DOMContentLoaded", function () {

            const typeSelect = document.getElementById("type");
            const orderDiv = document.getElementById("order_id");
            const itemDiv = document.getElementById("item_id");
            const orderSelect = document.querySelector("select[name='order_id']");
            const itemSelect = document.getElementById("itemSelect");

            // All items from backend (inject safely)
            const allItems = <%- JSON.stringify(items) %>;

            function toggleOrderField() {
                if (typeSelect.value === "order") {
                    orderDiv.style.display = "block";
                    itemDiv.style.display = "block";
                } else {
                    orderDiv.style.display = "none";
                    itemDiv.style.display = "none";
                }
            }

            function loadItemsForOrder(orderId) {

                itemSelect.innerHTML = "";

                const filtered = allItems.filter(i => i.so_id == orderId);

                filtered.forEach(i => {
                    const opt = document.createElement("option");
                    opt.value = i.item_id;
                    opt.textContent = i.product_name;
                    itemSelect.appendChild(opt);
                });
            }

            // initial
            toggleOrderField();

            // change type
            typeSelect.addEventListener("change", toggleOrderField);

            // change order → load items
            orderSelect.addEventListener("change", function () {
                loadItemsForOrder(this.value);
            });

            // initial load (first order)
            if (orderSelect.value) {
                loadItemsForOrder(orderSelect.value);
            }

        });
    </script>
</body>

</html>