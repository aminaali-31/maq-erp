<style>
    :root {
        --sidebar-bg: #f8f7ff; /* Very light violet/white background */
        --primary-violet: #8b5cf6;
        --nav-text: #7c7c9c;
        --nav-hover-bg: #f0edff;
        --brand-violet: #7d2ae8;
    }

    /* Modern Sidebar Styling */
    #sidebar {
        background-color: var(--sidebar-bg);
        height: 100vh; /* Fixed viewport height */
        width: 120px; /* Slimmer, icon-focused width */
        padding: 0;
        box-shadow: 1px 0 10px rgba(0, 0, 0, 0.03);
        z-index: 1050;
        position: fixed;
        left: 0;
        top: 0;
        display: flex;
        flex-direction: column;
        border-right: 1px solid #eee;
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    }

    /* Scrollable container for nav items */
    .sidebar-content {
        flex: 1;
        overflow-y: auto;
        overflow-x: hidden;
        padding-bottom: 20px;
    }

    /* Hide scrollbar for Chrome, Safari and Opera */
    .sidebar-content::-webkit-scrollbar {
        width: 4px;
    }
    .sidebar-content::-webkit-scrollbar-thumb {
        background: #e2e2ff;
        border-radius: 10px;
    }

    /* Mobile Backdrop Overlay */
    #sidebar-overlay {
        display: none;
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: rgba(0, 0, 0, 0.3);
        backdrop-filter: blur(2px);
        z-index: 1040;
    }

    #sidebar-overlay.active {
        display: block;
    }

    .sidebar-brand {
        padding: 1.25rem 0;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
    }

    /* The "Create" button style */
    .btn-create {
        background-color: var(--primary-violet);
        color: white !important;
        width: 44px;
        height: 44px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        box-shadow: 0 4px 12px rgba(139, 92, 246, 0.3);
        margin-bottom: 0.4rem;
        transition: transform 0.2s;
        text-decoration: none;
    }

    .btn-create:hover {
        transform: scale(1.05);
    }

    .brand-label {
        font-size: 0.65rem;
        font-weight: 700;
        color: var(--brand-violet);
        text-transform: uppercase;
        letter-spacing: 0.05em;
    }

    .nav-item {
        width: 100%;
        margin-bottom: 2px;
    }

    .nav-link {
        padding: 0.6rem 0.2rem;
        color: var(--nav-text) !important;
        font-size: 12px !important;
        font-weight: 600;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        text-align: center;
        text-decoration: none;
        transition: all 0.2s ease;
        border-radius: 10px;
        margin: 0 8px;
    }

    .nav-link i {
        font-size: 1.25rem;
        margin-bottom: 2px;
        display: block;
    }

    .nav-link:hover, .nav-link.active {
        background: var(--nav-hover-bg);
        color: var(--primary-violet) !important;
    }

    /* Submenu handling */
    .submenu {
        background: white;
        margin: 0 8px 8px 8px;
        border-radius: 8px;
        box-shadow: inset 0 2px 4px rgba(0,0,0,0.03);
    }
    
    .submenu .nav-link {
        flex-direction: row;
        font-size: 0.75rem;
        padding: 0.5rem 0.75rem;
        justify-content: flex-start;
        gap: 8px;
        text-align: left;
        margin: 0;
    }

    /* Responsive adjustments */
    @media (max-width: 767.98px) {
        #sidebar {
            transform: translateX(-100%);
            width: 260px;
        }
        #sidebar.active {
            transform: translateX(0);
        }
        .nav-link {
            flex-direction: row;
            justify-content: flex-start;
            padding: 0.8rem 1.25rem;
            font-size: 0.9rem;
            text-align: left;
            margin: 0 10px;
        }
        .nav-link i {
            margin-bottom: 0;
            margin-right: 15px;
            font-size: 1.4rem;
        }
        .mobile-navbar {
            background-color: var(--sidebar-bg);
            color: var(--nav-text);
        }
        .brand-label {
            font-size: 0.8rem;
        }
    }
</style>

<!-- Bootstrap CSS & Icons -->
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
