<html lang="en">
<head>
    <%- include('../head') %>
    <title>Document</title>
     <style>
        .star-rating {
            font-size: 1.5rem;
            color: #e3dbdb;
            cursor: pointer;
        }
        .star-rating input {
            display: none;
        }
        .star-rating label:hover,
        .star-rating label:hover ~ label,
        .star-rating input:checked ~ label {
            color: rgb(240, 212, 27);
        }
    </style>
</head>
<body>
    <%- include('nav') %>

    <div class="container my-5">
        <h1 class="mb-4 text-center">My Complaints</h1>

        <% if (complaints.length === 0) { %>
            <div class="alert alert-info text-center">You have not submitted any complaints yet.</div>
        <% } else { %>
            <div class="row g-4">
                <% complaints.forEach(complaint => { %>
                    <div class="col-md-6">
                        <div class="card shadow-sm h-100">
                            <div class="card-body d-flex flex-column">
                                <p class="card-text"><strong>Message:</strong> <%= complaint.message %></p>
                                <p class="card-text"><strong>Status:</strong> 
                                    <% if (complaint.status === 'pending') { %>
                                        <span class="badge bg-warning text-dark">Pending</span>
                                    <% } else if (complaint.status === 'processing') { %>
                                        <span class="badge bg-info text-dark">Processing</span>
                                    <% } else if (complaint.status === 'completed') { %>
                                        <span class="badge bg-success">Completed</span>
                                    <% } else { %>
                                        <span class="badge bg-secondary"><%= complaint.status %></span>
                                    <% } %>
                                </p>
                                <p class="card-text"><strong>Date:</strong> <%= new Date(complaint.date).toLocaleDateString() %></p>

                                <!-- Star feedback -->
                                <div class="mt-auto">
                                <% if (complaint.feedback) { %>
                                    <!-- Show existing feedback -->
                                    <div class="star-rating">
                                        <% for(let i = 1; i <= 5; i++) { %>
                                            <span class="<%= i <= complaint.feedback ? 'text-warning' : 'text-secondary' %>">&#9733;</span>
                                        <% } %>
                                        <small class="ms-2">Your Rating</small>
                                    </div>
                                <% } else { %>
                                    <!-- Allow user to submit -->
                                    <form action="/customer/complaints/<%= complaint.id %>/feedback" method="POST" class="star-rating d-flex justify-content-start">
                                        <input type="radio" name="rating" id="star5-<%= complaint.id %>" value="5"><label for="star5-<%= complaint.id %>">&#9733;</label>
                                        <input type="radio" name="rating" id="star4-<%= complaint.id %>" value="4"><label for="star4-<%= complaint.id %>">&#9733;</label>
                                        <input type="radio" name="rating" id="star3-<%= complaint.id %>" value="3"><label for="star3-<%= complaint.id %>">&#9733;</label>
                                        <input type="radio" name="rating" id="star2-<%= complaint.id %>" value="2"><label for="star2-<%= complaint.id %>">&#9733;</label>
                                        <input type="radio" name="rating" id="star1-<%= complaint.id %>" value="1"><label for="star1-<%= complaint.id %>">&#9733;</label>
                                        <button type="submit" class="btn btn-sm btn-primary ms-2">Submit</button>
                                    </form>
                                <% } %>
                            </div>
                            </div>
                        </div>
                    </div>
                <% }); %>
            </div>
        <% } %>

        <!-- Add Complaint Form -->
        <div class="mt-5">
            <h2>Add a New Complaint</h2>
            <% if (typeof error !== 'undefined') { %>
                <div class="alert alert-danger"><%= error %></div>
            <% } %>
            <% if (typeof success !== 'undefined') { %>
                <div class="alert alert-success"><%= success %></div>
            <% } %>
            <form action="/customer/complaints/add" method="POST">
                <div class="mb-3">
                    <label for="message" class="form-label">Complaint Message</label>
                    <textarea class="form-control" id="message" name="message" rows="3" required></textarea>
                </div>
                <button type="submit" class="btn btn-success">Submit Complaint</button>
            </form>
        </div>
    </div>


</body>
</html>