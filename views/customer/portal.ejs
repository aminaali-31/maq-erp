<!DOCTYPE html>
<html lang="en">
<head>
    <%- include('../head') %>
    <title>Document</title>
</head>
<body>
   <%- include('nav') %>
    <!-- Main Content -->
    <div class="container my-5">
        <h1 class="text-center mb-4">Welcome, <%= customer.name %>!</h1>

        <div class="row text-center">
            <div class="col-md-6 mb-3">
                <div class="card shadow-sm">
                    <div class="card-body">
                        <h5 class="card-title">Total Orders</h5>
                        <p class="display-4"><%= orders %></p>
                        <a href="/customer/orders" class="btn btn-primary">View Orders</a>
                    </div>
                </div>
            </div>

            <div class="col-md-6 mb-3">
                <div class="card shadow-sm">
                    <div class="card-body">
                        <h5 class="card-title">Total Complaints</h5>
                        <p class="display-4"><%= complaints %></p>
                        <a href="/customer/complaints" class="btn btn-primary">View Complaints</a>
                    </div>
                </div>
            </div>
        </div>

        <!-- Optional extra actions -->
        <div class="text-center mt-4">
            <a href="/customer/ledger" class="btn btn-success me-2">View Ledger</a>
            <a href="/customer/complaints/add" class="btn btn-warning">Add Complaint</a>
        </div>
    </div>

</body>
</html>