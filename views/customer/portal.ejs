<!DOCTYPE html>
<html lang="en">
<head>
    <%- include('../head') %>
    <title>Document</title>
    <style>
        .custom-card {
            border-left: 3px solid #7C4DFF;
        }
    </style>
</head>
<body>
   <%- include('nav') %>
    <!-- Main Content -->
    <div class="container my-5">
        <a href="javascript:history.back()">
                        <i class="bi bi-arrow-left"></i>
                    </a>
        <h1 class="text-center mb-4">Welcome, <%= customer.name %>!</h1>

        <div class="row text-center d-flex" style="justify-content: center;">
            <div class="col-md-4 mb-3">
                <div class="metric-card custom-card">
                    <div class="custom-card-body">
                        <h5 class="custom-card-header">Total Orders</h5>
                        <p class="display-4"><%= orders %></p>
                        <a href="/customer/orders" class="btn btn-primary">View Orders</a>
                    </div>
                </div>
            </div>

            <div class="col-md-4 mb-3">
                <div class="metric-card custom-card">
                    <div class="custom-card-body">
                        <h5 class="custom-card-header">Total Complaints</h5>
                        <p class="display-4"><%= complaints %></p>
                        <a href="/customer/complaints" class="btn btn-primary">View Complaints</a>
                    </div>
                </div>
            </div>
        </div>

        <!-- Optional extra actions -->
        <div class="text-center mt-4 d-flex align-items-center" style="justify-content: center;">
            <a href="/customer/ledger" class="btn action-btn me-2">View Ledger</a>
            <a href="/customer/complaints" class="btn action-btn">Add Complaint</a>
        </div>
    </div>

</body>
</html>