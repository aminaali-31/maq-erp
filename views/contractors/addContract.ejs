<!DOCTYPE html>
<html lang="en">
<head>
    <%- include('../head') %>
    <title>Add a Contract</title>
</head>
<body>
<div class="container fluid">
  <div class="row position-sticky">
    <%- include('../sidebar') %>
    <main class="col-md-9 col-lg-10 p-4">
      <a href="javascript:history.back()">
                        <i class="bi bi-arrow-left"></i>
                    </a>
        <div class="container mt-5">
            <h2 class="mb-4">Add Purchase Order</h2>

            <% if (message) { %>
                <div class="alert alert-success"><%= message %></div>
            <% } %>
            <div class="container mt-4">

    <div class="card shadow-sm">

        <!-- Header -->
        <div class="card-header d-flex justify-content-between align-items-center">
            <h5 class="mb-0">
                <i class="bi bi-file-earmark-text text-primary"></i>
                Add Contract
            </h5>

            <a href="/contractors/allContracts" class="btn btn-sm btn-outline-secondary">
                Back to Contracts
            </a>
        </div>

        <!-- Body -->
        <div class="card-body">

            <form method="POST" action="/contractors/addContract">

                <div class="row g-3">

                    <!-- Contractor -->
                    <div class="col-md-6">
                        <label class="form-label">
                            Contractor
                        </label>

                        <select 
                            name="contractor_id"
                            class="form-select"
                            required
                        >
                            <option value="">
                                Select Contractor
                            </option>

                            <% contractors.forEach(c => { %>
                                <option value="<%= c.id %>">
                                    <%= c.name %>
                                </option>
                            <% }) %>

                        </select>
                    </div>

                    <!-- Contract Name -->
                    <div class="col-md-6">
                        <label class="form-label">
                            Contract Name
                        </label>

                        <input 
                            type="text"
                            name="name"
                            class="form-control"
                            placeholder="Enter contract name"
                            required
                        >
                    </div>

                    <!-- Amount -->
                    <div class="col-md-4">
                        <label class="form-label">
                            Amount
                        </label>

                        <input 
                            type="number"
                            step="0.01"
                            name="amount"
                            class="form-control"
                            placeholder="0.00"
                            required
                        >
                    </div>

                    <!-- Start Date -->
                    <div class="col-md-4">
                        <label class="form-label">
                             Date
                        </label>

                        <input 
                            type="date"
                            name="date"
                            class="form-control"
                        >
                    </div>
                    <!-- Description -->
                    <div class="col-12">
                        <label class="form-label">
                            Description
                        </label>

                        <textarea 
                            name="description"
                            rows="3"
                            class="form-control"
                            placeholder="Enter contract details"
                        ></textarea>
                    </div>

                </div>

                <!-- Footer Buttons -->
                <div class="mt-4 d-flex justify-content-end gap-2">

                    <a href="/contractors/allContracts" class="btn btn-light">
                        Cancel
                    </a>

                    <button type="submit" class="btn btn-primary">
                        <i class="bi bi-check-circle"></i>
                        Save Contract
                    </button>

                </div>

            </form>

        </div>

    </div>

</div>
        </div>
        </main>
  </div>
  </div>
  </body>
  </html>