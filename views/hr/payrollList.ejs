<!DOCTYPE html>
<html lang="en">

<head>
    <%- include('../head') %>
        <title>Document</title>
</head>

<body>
    <div class="container fluid">
        <div class="row position-sticky">
            <%- include('../sidebar') %>
                <main class="col-md-9 col-lg-10 p-4">
                    <h2>Payroll List</h2>

                    <a href="/hr/payroll/add" class="btn btn-primary mb-3">
                        Add Payroll
                    </a>

                    <div class="table-responsive">
                        <table class="table table-bordered table-striped">

                            <thead class="table-dark">
                                <tr>
                                    <th>ID</th>
                                    <th>Employee</th>
                                    <th>Date</th>
                                    <th>Basic</th>
                                    <th>Allowance</th>
                                    <th>Overtime</th>
                                    <th>Deductions</th>
                                    <th>Net Salary</th>
                                    <th>Status</th>
                                </tr>
                            </thead>

                            <tbody>

                                <% if(payrolls.length===0){ %>
                                    <tr>
                                        <td colspan="9" class="text-center">
                                            No payroll records found
                                        </td>
                                    </tr>
                                    <% } %>

                                        <% payrolls.forEach(p=>{ %>
                                            <tr>
                                                <td>
                                                    <%= p.id %>
                                                </td>
                                                <td>
                                                    <%= p.employee_name %>
                                                </td>
                                                <td>
                                                    <%= p.date.toISOString().split('T')[0] %>
                                                </td>
                                                <td>
                                                    <%= p.basic_salary %>
                                                </td>
                                                <td>
                                                    <%= p.allowance %>
                                                </td>
                                                <td>
                                                    <%= p.overtime %>
                                                </td>
                                                <td>
                                                    <%= p.deductions %>
                                                </td>
                                                <td>
                                                    <strong>Rs. <%= Number(p.net_salary).toFixed(2) %></strong>
                                                </td>
                                                <td>
                                                    <span
                                                        class="badge bg-<%= p.status === 'paid' ? 'success' : 'warning' %>">
                                                        <%= p.status %>
                                                    </span>
                                                </td>
                                            </tr>
                                            <% }) %>

                            </tbody>

                        </table>
                    </div>
                </main>
        </div>
    </div>
</body>

</html>