<style>
    /* Modern Sidebar Styling */
    #sidebar {
        background-color: var(--sidebar-dark);
        min-height: 100vh;
        padding: 0;
        box-shadow: 4px 0 10px rgba(0, 0, 0, 0.05);
        z-index: 1000;
        position: fixed;
        left: 0;
        top: 0;
        overflow-y: auto;
    }
    &::-webkit-scrollbar {
    display: none;
  }

    .sidebar-brand {
        padding: 1rem 1.5rem;
        font-weight: 800;
        letter-spacing: -0.025em;
        color: white;
        font-size: 1.25rem;
        display: flex;
        align-items: center;
        gap: 0.75rem;
    }

    .nav-link {
        padding: 10px 1.5rem;
        color: #94a3b8 !important;
        font-size: 0.9rem;
        font-weight: 500;
        transition: all 0.2s ease;
        display: flex;
        align-items: center;
        gap: 0.75rem;
        border-left: 3px solid transparent;
        text-decoration: none;
    }

    .nav-link:hover {
        background: var(--sidebar-hover);
        color: white !important;
    }

    .nav-link i {
        font-size: 1.1rem;
    }

    /* Dynamic Active State Fix */
    .nav-link.active {
        color: white !important;
        background: rgba(139, 92, 246, 0.15) !important;
        /* Slightly more opaque for visibility */
        border-left-color: var(--primary-violet) !important;
    }

    /* Caret Rotation Fix */
    .nav-link[data-bs-toggle="collapse"] i.bi-caret-up-fill {
        font-size: 0.7rem;
        transition: transform 0.3s ease;
    }

    .nav-link[data-bs-toggle="collapse"].collapsed i.bi-caret-up-fill {
        transform: rotate(180deg);
    }

    @media (max-width: 767.98px) {
        .mobile-navbar {
            display: block;
        }

        #sidebar {
            transform: translateX(-100%);
            transition: transform 0.3s ease;
            width: 250px;
        }

        #sidebar.active {
            transform: translateX(0);
        }
    }
</style>
