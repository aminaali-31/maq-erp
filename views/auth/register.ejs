<!DOCTYPE html>
<html lang="en">
<head>
    <%- include('../head') %>
    <title>Register</title>
</head>
<body>
<div class="container mt-4">
    <h2>Resgister For a New Account</h2>
    <% if (error) { %>
        <div class="alert alert-danger">
            <%= error %>
        </div>
        <% } %>
    <form method="POST" action="/auth/register" class="form">
        <div class="mb-3">
        <label class="form-label">Username</label>
        <input type="text" class="form-control" name="username" placeholder="Full Name" required>
        </div>
        <div class="mb-3">
        <label class="form-label">Email</label>
        <input type="email" class="form-control" name="email" placeholder="Email" required>
        </div>
        <div class="mb-3">
        <label class="form-label">Password</label>
        <input type="password" class="form-control" name="password" placeholder="Password" required>
        </div>
        <div class="mb-3">
            <label for="form-select" class="form-label">Role</label>
            <select class="form-select" aria-label="Default select example" name="role_id">
                <% roles.forEach(function(role) { %>
                    <option value="<%= role.id %>"><%= role.name %></option>
                <% }); %>
            </select>
        </div>
        <div class="mb-3">
             <div class="g-recaptcha" data-sitekey="6LdGwYUsAAAAAJyH5V-SAYrPhTPp1VDV-gYhu_WM"></div>
        </div>
        <button type="submit" class="btn btn-primary">Register</button>
    </form>
</div>
<script src="https://www.google.com/recaptcha/api.js" async defer></script>
</body>
</html>