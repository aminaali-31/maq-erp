<!DOCTYPE html>
<html lang="en">

<head>
    <%- include('../head') %>
        <title>Register Customer</title>
</head>

<body>
    <%- include('../sidebar') %>

<div class="container fluid">
  <div class="row position-sticky">
    <%- include('../sidebar') %>
    <main class="col-md-9 col-lg-10 p-4">
      <a href="javascript:history.back()">
                        <i class="bi bi-arrow-left"></i>
                    </a>
            <h3 class="mb-4">Add New Customer</h3>

            <% if (success) { %>
            <div class="alert alert-success">
                <%= success %>
            </div>
            <% } %>

            <% if (error) { %>
            <div class="alert alert-danger">
                <%= error %>
            </div>
            <% } %>

            <form action="/auth/addCustomer" method="POST">
                <div class="card p-4">

                    <div class="mb-3">
                        <label class="form-label">Customer Name</label>
                        <input type="text" name="name" class="form-control"
                            placeholder="Enter customer name" required>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Phone</label>
                        <input 
                        type="tel"
                        name="phone"
                        pattern="03[0-9]{9}"
                        placeholder="03XXXXXXXXX"
                        class="form-control"
                        required
                    >
                    </div>
                    <div class="mb-3">
                        <label for="email" class="form-label">Email</label>
                        <input type="email" name="email" class="form-control"
                        placeholder="Email" required>
                    </div>
                    <div class="mb-3">
                        <label for="" class="form-label">Password</label>
                        <input type="password" name="password" class="form-control"
                            placeholder="Enter password" required>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Address</label>
                        <textarea name="address" class="form-control" rows="3"
                            placeholder="Enter customer address"></textarea>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Description</label>
                        <textarea name="description" class="form-control" rows="3"
                            placeholder="Additional notes about the customer"></textarea>
                    </div>
                    <div class="mb-3">
                        <label class="form-check-label">Create Account</label>
                        <input type="checkbox" class="checkbox form-check-input" name="is_active">
                    </div>

                    <div class="mt-3">
                        <button type="submit" class="btn btn-primary">
                            Save Customer
                        </button>

                        <a href="/customers" class="btn btn-secondary">
                            Cancel
                        </a>
                    </div>

                </div>
            </form>
    </main>
    </div>
    </div>
<style>
.main-content{
    margin-left: 250px; /* Match sidebar width */
    padding: 20px;
}
</style>
</body>
</html>