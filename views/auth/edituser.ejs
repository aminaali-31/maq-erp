<!DOCTYPE html>
<html lang="en">

<head>
    <%- include('../head') %>
        <title>Register</title>
</head>

<body>
 <div class="container fluid">
        <div class="row position-sticky">
            <%- include('../sidebar') %>
                <main class="col-md-9 col-lg-10 p-2">

            <h3>Edit User</h3>

            <form action="/auth/users/edit/<%= user.id %>" method="POST">

                <div class="mb-3">
                    <label class="form-label">Name</label>
                    <input type="text" name="name" class="form-control" value="<%= user.username %>" required>
                </div>
                <div class="mb-3">
                    <label for="password" class="form-label">Password</label>
                    <input type="password" name="password" id="password" placeholder="New password" class="form-control">
                </div>

                <div class="mb-3">
                    <label class="form-label">Email</label>
                    <input type="email" name="email" class="form-control" value="<%= user.email %>">
                </div>

                <div class="mb-3">
                    <label class="form-label">Role</label>
                    <% if(!isCustomer && !isVendor){ %>
                        <select name="role" class="form-select">
                            <% roles.forEach(role => { %>
                                <option value="<%= role.id %>" <%= user.role_id === role.id ? 'selected' : '' %>>
                                    <%= role.name.charAt(0).toUpperCase() + role.name.slice(1) %>
                                </option>
                            <% }) %>
                        </select>

                        <% } %>
                            <% if(isCustomer || isVendor){ %>
                                <small class="text-danger">
                                    This user is linked to a customer/vendor so the role cannot be changed.
                                </small>
                                <% } %>

                </div>

                <button class="btn btn-primary">Update</button>
                <a href="/auth/users" class="btn btn-secondary">Cancel</a>

            </form>

        </main>
        </div>
        </div>
        </body>
</html>