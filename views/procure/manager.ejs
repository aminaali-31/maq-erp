<!DOCTYPE html>
<html lang="en">

<head>
    <%- include('../head') %>
        <title>Manager Dashboard</title>

        <!-- Bootstrap 5 & Icons -->
        <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
        <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css" rel="stylesheet">
        <!-- Chart.js -->
</head>

<body>
    <div class="container-fluid">
        <div class="row p-2">
            <!-- Sidebar (Assuming your sidebar EJS handles its own col-md-3 etc.) -->
            <%- include('../sidebar') %>

                <main class="col-md-9 col-lg-10 p-4">
                    <div class="d-flex justify-content-between align-items-center">
                        <a href="javascript:history.back()">

                            <i class="bi bi-arrow-left"></i>

                        </a>
                        <div>
                            <p class="custom-card-header" style="font-size: 23px;">Hello, <%=
                                    user.full_name[0].toUpperCase() + user.full_name.slice(1) %>
                            </p>
                        </div>
                    </div>


                    <!-- ============================= -->

                    <!-- Key Summary Cards -->

                    <!-- ============================= -->

                    <div class="row g-3" style="margin-bottom: 30px;">



                        <div class="col-lg-3 col-md-2">

                            <div class="metric-card">

                                <div class="metric-icon"><i class="bi bi-currency-dollar"></i></div>

                                <div>

                                    <p class="metric-title">Total Sales</p>

                                    <h4>

                                        <%= Number(summary.totalSales).toLocaleString() %>

                                    </h4>

                                </div>

                            </div>

                        </div>



                        <div class="col-lg-3 col-md-2">

                            <div class="metric-card">

                                <div class="metric-icon"><i class="bi bi-box-seam"></i></div>

                                <div>

                                    <p class="metric-title">Sales Orders</p>

                                    <h4>

                                        <%= summary.totalOrders %>

                                    </h4>

                                </div>

                            </div>

                        </div>



                        <div class="col-lg-3 col-md-6">

                            <div class="metric-card">

                                <div class="metric-icon"><i class="bi bi-credit-card"></i></div>

                                <div>

                                    <p class="metric-title">Pending Receivables</p>

                                    <h4>

                                        <%= Number(summary.pendingReceivables).toLocaleString() %>

                                    </h4>

                                </div>

                            </div>

                        </div>



                        <div class="col-lg-3 col-md-6">

                            <div class="metric-card">

                                <div class="metric-icon"><i class="bi bi-bag-check"></i></div>

                                <div>

                                    <p class="metric-title">Purchase Orders</p>

                                    <h4>

                                        <%= summary.totalPO %>

                                    </h4>

                                </div>

                            </div>

                        </div>



                        <div class="col-lg-3 col-md-6">

                            <div class="metric-card">

                                <div class="metric-icon"><i class="bi bi-cash-stack"></i></div>

                                <div>

                                    <p class="metric-title">Pending Payables</p>

                                    <h4>

                                        <%= Number(summary.pendingPayables).toLocaleString() %>

                                    </h4>

                                </div>

                            </div>

                        </div>



                        <div class="col-lg-3 col-md-6">

                            <div class="metric-card">

                                <div class="metric-icon"><i class="bi bi-exclamation-triangle"></i></div>

                                <div>

                                    <p class="metric-title">Low Stock Items</p>

                                    <h4>

                                        <%= summary.lowStockCount %>

                                    </h4>

                                </div>

                            </div>

                        </div>



                        <div class="col-lg-3 col-md-6">

                            <div class="metric-card">

                                <div class="metric-icon"><i class="bi bi-boxes"></i></div>

                                <div>

                                    <p class="metric-title">Total Products</p>

                                    <h4>

                                        <%= summary.totalProducts %>

                                    </h4>

                                </div>

                            </div>

                        </div>



                    </div>

                    <!-- Quick Actions -->
                    <div class="row g-3 mb-5">
                        <div class="col-6 col-md-auto">
                            <a href="/sales/orders/new" class="action-btn">
                                <i class="bi bi-plus-lg"></i> Add Sale
                            </a>
                        </div>
                        <div class="col-6 col-md-auto">
                            <a href="/sales/orders" class="action-btn">
                                <i class="bi bi-box-seam"></i> Sales Orders
                            </a>
                        </div>
                        <div class="col-6 col-md-auto">
                            <a href="/procure/purchase-orders/add" class="action-btn">
                                <i class="bi bi-cart-plus"></i> Purchase Order
                            </a>
                        </div>
                        <div class="col-6 col-md-auto">
                            <a href="/procure/purchase-orders/all" class="action-btn">
                                <i class="bi bi-gear"></i> Procurement
                            </a>
                        </div>
                        <div class="col-6 col-md-auto">
                            <a href="/inventory/allProducts" class="action-btn">
                                <i class="bi bi-archive"></i> Inventory
                            </a>
                        </div>
                    </div>

                    <div class="row">

                        <!-- Jobs Section (2/3 width) -->
                        <div class="col-md-8 mb-3">
                            <div class="custom-card h-100">
                                <div class="custom-card-header">
                                    <i class="bi bi-list-task text-primary"></i> Tasks to Do
                                </div>

                                <div class="table-responsive">
                                    <table class="table mb-0">
                                        <thead>
                                            <tr>
                                                <th>Title</th>
                                                <th>Description</th>
                                                <th>Status</th>
                                                <th>Due Date</th>
                                                <th>Comment</th>
                                            </tr>
                                        </thead>

                                        <tbody>
                                            <% jobs.forEach(job=> { %>
                                                <tr>
                                                    <td class="fw-bold">
                                                        <%= job.title %>
                                                    </td>
                                                    <td class="text-muted">
                                                        <%= job.description %>
                                                    </td>

                                                    <td>
                                                        <span
                                                            class="badge bg-light text-primary border border-primary-subtle">
                                                            <%= job.status %>
                                                        </span>
                                                    </td>

                                                    <td class="font-monospace">
                                                        <%= job.due_date.toLocaleDateString('en-CA') %>
                                                    </td>
                                                    <td>
                                                        <form action="/admin/job/<%= job.id %>" method="POST">
                                                            <input type="text" name="comment"
                                                                value="<%= job.comment || '' %>"
                                                                class="form-control form-control-sm mt-1"
                                                                placeholder="Enter comment">
                                                            <button type="submit"
                                                                class="btn btn-sm btn-primary mt-1">Update</button>
                                                        </form>
                                                    </td>
                                                </tr>
                                                <% }) %>
                                        </tbody>

                                    </table>
                                </div>
                            </div>
                        </div>

                        <!-- Inventory Levels Section (1/3 width) -->
                        <div class="col-md-4 mb-3">
                            <div class="custom-card h-100">
                                <div class="custom-card-header">
                                    <i class="bi bi-box-seam text-primary"></i> Inventory Levels
                                </div>

                                <div class="table-responsive">
                                    <table class="table mb-0">
                                        <thead>
                                            <tr>
                                                <th>Id</th>
                                                <th>Category</th>
                                                <th>Quantity</th>
                                            </tr>
                                        </thead>

                                        <tbody>
                                            <% po_items.forEach(po_item=> { %>
                                                <tr>
                                                    <td class="fw-bold">
                                                        <%= po_item.category_id %>
                                                    </td>

                                                    <td class="text-muted">
                                                        <%= po_item.category_name %>
                                                    </td>

                                                    <td class="font-monospace">
                                                        <%= po_item.total_quantity %>
                                                    </td>
                                                </tr>
                                                <% }) %>
                                        </tbody>

                                    </table>
                                </div>
                            </div>
                        </div>

                    </div>

                    <!-- Tables Row -->
                    <div class="row">
                        <div class="col-lg-6">
                            <div class="custom-card">
                                <div class="custom-card-header">Latest Sales Orders</div>
                                <div class="table-responsive">
                                    <table class="table mb-0">
                                        <thead>
                                            <tr>
                                                <th>ID</th>
                                                <th>Customer</th>
                                                <th>Amount</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            <% recentSalesOrders.forEach(order=> { %>
                                                <tr>
                                                    <td class="text-primary fw-bold">#<%= order.id %>
                                                    </td>
                                                    <td>
                                                        <%= order.customer %>
                                                    </td>
                                                    <td class="fw-bold text-end">PKR <%=
                                                            Number(order.total_amount).toLocaleString() %>
                                                    </td>
                                                </tr>
                                                <% }) %>
                                        </tbody>
                                    </table>
                                </div>
                            </div>
                        </div>
                        <div class="col-lg-6">
                            <div class="custom-card">
                                <div class="custom-card-header">Latest Purchase Orders</div>
                                <div class="table-responsive">
                                    <table class="table mb-0">
                                        <thead>
                                            <tr>
                                                <th>ID</th>
                                                <th>Vendor</th>
                                                <th>Amount</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            <% recentPOs.forEach(po=> { %>
                                                <tr>
                                                    <td class="text-info fw-bold">#<%= po.id %>
                                                    </td>
                                                    <td>
                                                        <%= po.vendor %>
                                                    </td>
                                                    <td class="fw-bold text-end">PKR <%=
                                                            Number(po.total_amount).toLocaleString() %>
                                                    </td>
                                                </tr>
                                                <% }) %>
                                        </tbody>
                                    </table>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Analytics Row -->
                    <div class="row mb-4">

                        <!-- First chart: 3/4 width -->

                        <div class="col-md-9 mb-3">

                            <div class="custom-card">

                                <div class="custom-card-body">

                                    <h6 class=" mb-3">Sales vs Purchase Analytics</h6>

                                    <div class="chart-container">

                                        <canvas id="financeChart"></canvas>

                                    </div>

                                </div>

                            </div>

                        </div>



                        <!-- Pie chart: 1/4 width -->

                        <div class="col-md-3 mb-3">

                            <div class="custom-card">

                                <div class="custom-card-body">

                                    <h6 class="mb-3">Order Distribution</h6>

                                    <div class="chart-container">

                                        <canvas id="orderChart"></canvas>

                                    </div>

                                </div>

                            </div>

                        </div>





                        <div class="col-lg-12 mt-4 mb-2">

                            <div class="custom-card">

                                <div class="custom-card-body">

                                    <h6 class="mb-3">Sales Trend</h6>

                                    <div class="chart-container">

                                        <canvas id="salesTrendChart"></canvas>

                                    </div>

                                </div>

                            </div>

                        </div>

                    </div>

                </main>
        </div>
    </div>
    <script>
        document.addEventListener('DOMContentLoaded', async () => {

            const userRole = "<%= user.role_id || '' %>";
            if (userRole !== '1') return;

            const res = await fetch("/procure/manager/new-updates");
            const data = await res.json();
            const name = <%- JSON.stringify(user.full_name) %>;
            const synth = window.speechSynthesis;
            let selectedVoice;

            function loadVoices() {
                const voices = synth.getVoices();
                selectedVoice = voices.find(v => v.lang === "en-US") || voices[0];
            }

            loadVoices();
            speechSynthesis.onvoiceschanged = loadVoices;

            function speak(text, callback) {
                const speech = new SpeechSynthesisUtterance(text);
                speech.voice = selectedVoice;
                speech.lang = "en-US";
                speech.rate = 1;

                if (callback) speech.onend = callback;

                synth.speak(speech);
            }

            setTimeout(() => {

                speak(
                    `Hello ${name}. ${data.message}`,
                );

            }, 1000);


            function listenForResponse() {

                const SpeechRecognition = window.SpeechRecognition || window.webkitSpeechRecognition;
                if (!SpeechRecognition) return;

                const recognition = new SpeechRecognition();
                recognition.lang = 'en-US';

                recognition.onresult = (event) => {

                    const result = event.results[0][0].transcript.toLowerCase();
                    recognition.stop();

                    if (result.includes("yes")) {

                        speak(data.message);

                    } else {

                        speak("Okay. Let me know if you need anything.");

                    }

                };

                recognition.start();
            }

        });
    </script>
    <!-- Chart.js -->
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        const months = <%- JSON.stringify(monthlySales.map(m => m.month)) %>;
        const salesData = <%- JSON.stringify(monthlySales.map(m => m.totalSales)) %>;
        const purchasesData = <%- JSON.stringify(monthlyPurchases.map(m => m.totalPurchases)) %>;
        // Finance Chart
        const financeCtx = document.getElementById('financeChart').getContext('2d');
        const monthlyChart = new Chart(financeCtx, {
            type: 'bar',
            data: {
                labels: months, // e.g., ['Jan','Feb','Mar']
                datasets: [
                    {
                        label: 'Sales',
                        data: salesData,
                        backgroundColor: '#7C4DFF',
                        borderRadius: 5,    // rounded bar corners
                        barPercentage: 0.5
                    },
                    {
                        label: 'Purchases',
                        data: purchasesData,
                        backgroundColor: '#23e795',
                        borderRadius: 5,
                        barPercentage: 0.5
                    }
                ]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: {
                    legend: {
                        position: 'bottom',
                        labels: {
                            usePointStyle: true,
                            pointStyle: 'circle'
                        }
                    },
                    tooltip: {
                        mode: 'index',
                        intersect: false
                    }
                },
                scales: {
                    y: {
                        beginAtZero: true,
                        title: {
                            display: true,
                            text: 'Amount'
                        }
                    },
                    x: {
                        title: {
                            display: true,
                            text: 'Month'
                        }
                    }
                }
            }
        });

        // Order Distribution Chart
        const orderCtx = document.getElementById('orderChart');
        new Chart(orderCtx, {
            type: 'doughnut',
            data: {
                labels: ['Sales Orders', 'Purchase Orders'],
                datasets: [{
                    data: [<%= summary.totalOrders %>, <%= summary.totalPO %>],
                    backgroundColor: ['#7C4DFF', '#FF9800'],
                    borderWidth: 1,
                    borderRadius: 10,
                    spacing: -5
                }]
            },
            options: { cutout: '85%', responsive: true, plugins: { legend: { position: 'bottom', labels: { usePointStyle: true, pointStyle: 'circle', padding: 20 } } } }
        });

        // Sales Trend Chart
        const salesTrendCtx = document.getElementById('salesTrendChart');
        const salesAmounts = <%- JSON.stringify(monthlySales.map(m => m.totalSales)) %>;
        const salesCounts = <%- JSON.stringify(monthlySales.map(m => m.totalOrders)) %>;

        new Chart(salesTrendCtx, {
            type: 'line',
            data: {
                labels: months,
                datasets: [
                    {
                        label: 'Sales Amount',
                        data: salesAmounts,
                        borderColor: '#8B5CF6',
                        backgroundColor: 'rgba(139, 92, 246, 0.1)',
                        fill: true,
                        borderWidth: 3,
                        tension: 0.4,
                        pointRadius: 4,
                    },
                    {
                        label: 'Number of Orders',
                        data: salesCounts,
                        borderColor: '#FF9800',
                        backgroundColor: '#FF9800',
                        borderWidth: 3,
                        tension: 0.4,
                        pointRadius: 4,
                        fill: false
                    }
                ]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: { legend: { display: false } },
                scales: {
                    y: { grid: { color: '#f1f5f9' }, border: { display: false } },
                    x: { grid: { display: false }, border: { display: false } }
                }
            }
        });
    </script>
</body>