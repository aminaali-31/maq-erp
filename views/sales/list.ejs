<!DOCTYPE html>
<html lang="en">

<head>
    <style>
    .sortable {
        cursor: pointer;
        user-select: none;
    }

    .sortable:hover {
        color: #0d6efd;
    }
</style>
    <%- include('../head') %>
        <title>Orders List</title>
</head>

<body>
    <div class="container fluid">
        <div class="row position-sticky">
            <%- include('../sidebar') %>
                <main class="col-md-9 col-lg-10 p-2">
                    <a href="javascript:history.back()">
                        <i class="bi bi-arrow-left"></i>
                    </a>
                    <div class="container mt-5">
                        <h3>Sales Orders</h3>
                        <a href="/sales/orders/new" class="btn btn-primary mb-3">New Order</a>
                        <% if(success){ %>
                            <div class="alert alert-success">
                                <%= success %>
                            </div>
                            <% } %>
                                <% if(error){ %>
                                    <div class="alert alert-danger">
                                        <%= error %>
                                    </div>
                                    <% } %>
                                        <div class="row mb-3">
                                            <div class="col-md-4">
                                                <input type="text" id="searchInput" class="form-control"
                                                    placeholder="Search product name or category...">
                                            </div>
                                        </div>
                                        <div class="card p-2">
                                            <div class="table-responsive">
                                                <table class="table">
                                                    <thead>
                                                        <tr>
                                                            <th>Sr.</th>
                                                            <th class="sortable" data-sort="customer">Customer ↕</th>
                                                            <th class="sortable" data-sort="amount">Total Amount ↕</th>
                                                            <th class="sortable" data-sort="profit">Profit ↕</th>
                                                            <th>Payment Status</th>
                                                            <th>Order Status</th>
                                                            <th class="sortable" data-sort="date">Date ↕</th>
                                                            <th>Action</th>
                                                        </tr>
                                                    </thead>
                                                    <tbody>
                                                        <% orders.forEach((order, idx)=> { %>
                                                            <tr
                                                                data-customer="<%= order.customer_name.toLowerCase() %>"
                                                                data-amount="<%= order.total_amount %>"
                                                                data-profit="<%= order.profit %>"
                                                                data-date="<%= new Date(order.date).getTime() %>">
                                                                <td>
                                                                    <%= idx+1 %>
                                                                </td>
                                                                <td>
                                                                    <%= order.customer_name %> - Order no.  <%= order.id %> 
                                                                </td>
                                                                <td>
                                                                    <%= Number(order.total_amount).toLocaleString() %>
                                                                </td>
                                                                <td>
                                                                    <%= Number(order.profit).toLocaleString() %>
                                                                </td>
                                                                <td>
                                                                    <form action="/sales/orders/status" method="POST"
                                                                        class="d-flex gap-2">
                                                                        <input type="hidden" name="order_id"
                                                                            value="<%= order.id %>">
                                                                        <select name="status"
                                                                            class="form-select form-select-sm">
                                                                            <option value="pending"
                                                                                <%=order.status==='pending'
                                                                                ?'selected':'' %>>Pending</option>
                                                                            <option value="completed"
                                                                                <%=order.status==='completed'
                                                                                ?'selected':'' %>
                                                                                >Paid</option>

                                                                        </select>
                                                                </td>
                                                                <td>
                                                                    <input type="hidden" name="order_id"
                                                                        value="<%= order.id %>">
                                                                    <div class="d-flex align-items-center gap-2">


                                                                        <select name="progress"
                                                                            class="form-select form-select-sm">

                                                                            <option value="pending"
                                                                                <%=order.progress==='pending'
                                                                                ? 'selected' : '' %>>
                                                                                Pending
                                                                            </option>

                                                                            <option value="happening"
                                                                                <%=order.progress==='happening'
                                                                                ? 'selected' : '' %>>
                                                                                Happening
                                                                            </option>

                                                                            <option value="halted"
                                                                                <%=order.progress==='halted'
                                                                                ? 'selected' : '' %>>
                                                                                Halted
                                                                            </option>

                                                                            <option value="signed off"
                                                                                <%=order.progress==='signed off'
                                                                                ? 'selected' : '' %>>
                                                                                Signed off
                                                                            </option>

                                                                        </select>
                                                                        <button class="btn btn-sm btn-primary">
                                                                            Update
                                                                        </button>
                                                                    </div>
                                                                    </form>
                                                                </td>
                                                                <td>
                                                                    <%= new Date(order.date).toLocaleDateString() %>
                                                                </td>
                                                                <td>
                                                                    <a href="/sales/orders/view/<%= order.id %>"
                                                                        class="btn btn-primary">View</a>
                                                                    <% if(order.progress==='pending' ){ %>
                                                                        <a href="/sales/orders/edit/<%= order.id %>"
                                                                            class="btn btn-primary">
                                                                            Edit
                                                                        </a>
                                                                        <% } %>
                                                                </td>
                                                            </tr>
                                                            <% }) %>
                                                    </tbody>
                                                </table>
                                            </div>
                                        </div>
                </main>
        </div>
    </div>
    <script>
        document.getElementById("searchInput").addEventListener("keyup", function () {
            let filter = this.value.toLowerCase();
            let rows = document.querySelectorAll("tbody tr");

            rows.forEach(row => {
                let text = row.innerText.toLowerCase();

                if (text.includes(filter)) {
                    row.style.display = "";
                } else {
                    row.style.display = "none";
                }
            });
        });
    </script>
    <script>
    document.getElementById("searchInput").addEventListener("keyup", function () {
        let filter = this.value.toLowerCase();
        let rows = document.querySelectorAll("tbody tr");

        rows.forEach(row => {
            let text = row.innerText.toLowerCase();
            row.style.display = text.includes(filter) ? "" : "none";
        });
    });

    let sortDirection = {};

    document.querySelectorAll(".sortable").forEach(header => {
        header.addEventListener("click", function () {
            const key = this.dataset.sort;
            const tbody = document.querySelector("tbody");
            const rows = Array.from(tbody.querySelectorAll("tr"));

            sortDirection[key] = sortDirection[key] === "asc" ? "desc" : "asc";

            rows.sort((a, b) => {
                let aValue = a.dataset[key];
                let bValue = b.dataset[key];

                if (key === "amount" || key === "profit" || key === "date") {
                    aValue = Number(aValue);
                    bValue = Number(bValue);
                }

                if (aValue < bValue) {
                    return sortDirection[key] === "asc" ? -1 : 1;
                }

                if (aValue > bValue) {
                    return sortDirection[key] === "asc" ? 1 : -1;
                }

                return 0;
            });

            tbody.innerHTML = "";
            rows.forEach(row => tbody.appendChild(row));
        });
    });
</script>
</body>

</html>