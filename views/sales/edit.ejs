<!DOCTYPE html>
<html lang="en">

<head>
    <%- include('../head') %>
    <title>Edit Sales Order</title>
</head>

<body>
    <div class="container-fluid">
        <div class="row position-sticky">
            <%- include('../sidebar') %>
            <main class="col-md-9 col-lg-10 p-4">
                <div class="container mt-4">
                    <h3 class="mb-4">Edit Sales Order #<%= order.id %></h3>

                    <% if (error) { %>
                        <div class="alert alert-danger"><%= error %></div>
                    <% } %>

                    <% if (success) { %>
                        <div class="alert alert-success"><%= success %></div>
                    <% } %>

                    <form action="/sales/orders/edit/<%= order.id %>" method="POST">
                        <div class="card p-3 mb-4">
                            <div class="row">
                                <div class="col-md-6 mb-3">
                                    <label class="form-label">Customer</label>
                                    <input type="text" class="form-control" value="<%= order.customer_name %>" disabled>
                                </div>
                                <div class="col-md-6 mb-3">
                                    <label class="form-label">Status</label>
                                    <input type="text" class="form-control" value="<%= order.status %>" disabled>
                                </div>
                            </div>
                        </div>

                        <!-- Order Items -->
                        <div class="card p-3">
                            <h5 class="mb-3">Order Items</h5>
                            <table class="table table-bordered" id="itemsTable">
                                <thead class="table-light">
                                    <tr>
                                        <th style="width:35%">Product</th>
                                        <th style="width:20%">Sale Price</th>
                                        <th style="width:15%">Quantity</th>
                                        <th style="width:20%">Warranty till</th>
                                        <th style="width:20%">Total</th>
                                        <th style="width:5%"></th>
                                    </tr>
                                </thead>
                                <tbody id="itemsBody">
                                    <% items.forEach(function(item, index){ %>
                                    <tr>
                                        <td>
                                            <select name="items[<%= index %>][product_data]" class="form-control">
                                                <option value="">Select Product Batch</option>
                                                <% productOptions.forEach(opt => {
                                                    const data = JSON.parse(opt.value);
                                                    const isSelected = Number(item.p_id) === Number(data.product_id) &&
                                                                    Number(item.batch_id) === Number(data.batch_id);
                                                %>
                                                    <option value='<%= opt.value %>' <%= isSelected ? 'selected' : '' %>>
                                                        <%= opt.label %>
                                                    </option>
                                                <% }) %>
                                            </select>
                                        </td>
                                        <td>
                                            <input type="number" step="0.01"
                                                name="items[<%= index %>][sale_price]"
                                                class="form-control price"
                                                value="<%= item.sale_price %>">
                                        </td>
                                        <td>
                                            <input type="number"
                                                name="items[<%= index %>][quantity]"
                                                class="form-control qty"
                                                value="<%= item.quantity %>" min="1">
                                        </td>
                                        <td>
                                            <input type="date" id="warranty" name="items[<%= index %>][warranty]" class="form-control"
                                            value="<%= item ? item.warranty : '' %>">
                                        </td>
                                        <td>
                                            <input type="text" class="form-control total" readonly>
                                        </td>
                                        <td>
                                            <button type="button" class="btn btn-danger btn-sm removeRow">X</button>
                                        </td>
                                    </tr>
                                <% }) %>
                                </tbody>
                            </table>

                            <button type="button" class="btn btn-secondary mb-3" id="addRow">Add Product</button>

                            <div class="text-end">
                                <h5>
                                    Grand Total: <span id="grandTotal">0</span>
                                </h5>
                            </div>
                        </div>

                        <div class="mt-3">
                            <button type="submit" class="btn btn-primary">Update Sales Order</button>
                        </div>
                    </form>
                </div>
            </main>
        </div>
    </div>

    <script>
        let rowIndex = <%= items.length %>;

        const productsData = <%- JSON.stringify(productOptions) %>;

        function calculateRow(row) {
            const price = parseFloat(row.querySelector(".price").value) || 0;
            const qty = parseFloat(row.querySelector(".qty").value) || 0;
            row.querySelector(".total").value = (price * qty).toFixed(2);
            calculateGrandTotal();
        }

        function calculateGrandTotal() {
            let grandTotal = 0;
            document.querySelectorAll(".total").forEach(el => {
                grandTotal += parseFloat(el.value) || 0;
            });
            document.getElementById("grandTotal").innerText = grandTotal.toFixed(2);
        }

        // Auto-fill price when product is selected
        document.addEventListener("change", function(e){
            if(!e.target.classList.contains("product-select")) return;
            const row = e.target.closest("tr");
            if(!row) return;
            try {
                const data = JSON.parse(e.target.value || "{}");
                const priceField = row.querySelector("input.price");
                const qtyField = row.querySelector("input.qty");

                if(priceField) priceField.value = data.price || 0;
                if(qtyField) {
                    qtyField.max = data.stock || 9999;
                    qtyField.value = 1;
                }

                calculateRow(row);
            } catch(err) {
                console.error("Product parse error", err);
            }
        });

        // Quantity / Price change
        document.addEventListener("input", function(e){
            if(e.target.classList.contains("qty") || e.target.classList.contains("price")){
                const row = e.target.closest("tr");
                calculateRow(row);
            }
        });

        // Remove row
        document.addEventListener("click", function(e){
            if(e.target.classList.contains("removeRow")){
                e.target.closest("tr").remove();
                calculateGrandTotal();
            }
        });

        // Add new row
        document.getElementById("addRow").addEventListener("click", function(){
            const tbody = document.getElementById("itemsBody");

            const row = `<tr>
                <td>
                    <select name="items[${rowIndex}][product_data]" class="form-control product-select" required>
                        <option value="">Select Product Batch</option>
                        ${productsData.map(opt => `<option value='${opt.value}'>${opt.label}</option>`).join('')}
                    </select>
                </td>
                <td>
                    <input type="number" step="0.01" name="items[${rowIndex}][sale_price]" class="form-control price">
                </td>
                <td>
                    <input type="number" name="items[${rowIndex}][quantity]" class="form-control qty" value="1" min="1">
                </td>
                 <td>
                    <input type="date" id="warranty" name="items[<%= index %>][warranty]" class="form-control"
                    value="<%= item ? item.warranty : '' %>">
                 </td>
                <td>
                    <input type="text" class="form-control total" readonly>
                </td>
                <td>
                    <button type="button" class="btn btn-danger btn-sm removeRow">X</button>
                </td>
            </tr>`;

            tbody.insertAdjacentHTML("beforeend", row);
            rowIndex++;
        });

        // Initial calculation on page load
        document.querySelectorAll("#itemsBody tr").forEach(row => calculateRow(row));
    </script>
</body>
</html>