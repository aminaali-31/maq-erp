<!DOCTYPE html>
<html lang="en">
<head>
    <%- include('../head') %>
    <title>Document</title>
</head>
<body>
    <div class="container fluid">
        <div class="row position-sticky">
    <%- include('../sidebar') %>
    <main class="col-md-9 col-lg-10 p-4">
        <a href="javascript:history.back()">
                        <i class="bi bi-arrow-left"></i>
                    </a>
        <div class="container mt-5">
        <% if (message) { %>
        <div class="alert alert-success">
            <%= message %>
        </div>
        <% } %>
        <h2 class="mb-4">Add New Product</h2>
        <form id="addProductForm" method="POST" action="/inventory/add">
            <!-- Product Name -->
            <div class="mb-3">
            <label for="name" class="form-label">Product Name</label>
            <input type="text" class="form-control" id="name" name="name" placeholder="Enter product name" required>
            </div>

            <!-- Category -->
            <div class="mb-3">
            <label for="category_id" class="form-label">Category</label>
            <select class="form-select" id="category_id" name="category_id" required>
                <option value="">Select Category</option>
                <% categories.forEach(category => { %>
                <option value="<%= category.id %>"><%= category.name %></option>
                <% }) %>
            </select>
            </div>

            <!-- Sale Price -->
            <div class="mb-3">
            <label for="sale_price" class="form-label">Sale Price</label>
            <input type="number" step="0.01" class="form-control" id="sale_price" name="sale_price" placeholder="Enter sale price" required>
            </div>

            <!-- Reorder Level -->
            <div class="mb-3">
            <label for="reorder_level" class="form-label">Reorder Level</label>
            <input type="number" class="form-control" id="reorder_level" name="reorder_level" placeholder="Enter reorder level">
            </div>

            <!-- Is Active -->
            <div class="mb-3">
            <label for="is_active" class="form-label">Status</label>
            <select class="form-select" id="is_active" name="is_active">
                <option value="yes" selected>Active</option>
                <option value="no">Inactive</option>
            </select>
            </div>

            <!-- Submit Button -->
            <button type="submit" class="btn btn-primary">Add Product</button>
        </form>
    </main>
        </div>
    </div>
</body>
</html>