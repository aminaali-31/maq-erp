<!DOCTYPE html>
<html lang="en">
<head>
    <%- include('../head') %>
    <title>Document</title>
</head>
<body>
    <div class="container fluid">
    <div class="row position-sticky">
    <%- include('../sidebar') %>
    <main class="col-md-9 col-lg-10 p-4">
        <div class="container mt-5">
            <h2 class="mb-4">Add New Category</h2>
            <form id="addCategoryForm">
                <!-- Category Name -->
                <div class="mb-3">
                <label for="name" class="form-label">Category Name</label>
                <input type="text" class="form-control" id="name" name="name" placeholder="Enter category name" required>
                </div>

                <!-- Submit Button -->
                <button type="submit" class="btn btn-primary">Add Category</button>
            </form>

            <!-- Feedback Alert -->
            <div id="alertCategoryMessage" class="mt-3"></div>
            </div>
    </main>
    </div>
    </div>
</body>
<script>
document.getElementById('addCategoryForm').addEventListener('submit', async function(e) {
    e.preventDefault();

    const formData = {
        name: document.getElementById('name').value
    };

    try {
        const res = await fetch('/inventory/category', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(formData)
        });

        const data = await res.json();
        const alertDiv = document.getElementById('alertCategoryMessage');

        if (res.ok) {
            alertDiv.innerHTML = `<div class="alert alert-success">${data.message}</div>`;
            document.getElementById('addCategoryForm').reset();
        } else {
            alertDiv.innerHTML = `<div class="alert alert-danger">${data.message}</div>`;
        }
    } catch (err) {
        console.error(err);
        document.getElementById('alertCategoryMessage').innerHTML =
            `<div class="alert alert-danger">Server error</div>`;
    }
});
</script>
</html>