<!DOCTYPE html>
<html lang="en">
<head>
    <%- include('../head') %>
    <title>Document</title>
</head>
<body>
    <div class="container fluid">
    <div class="row position-sticky">
    <%- include('../sidebar') %>
    <main class="col-md-9 col-lg-10 p-4">
        <a href="javascript:history.back()">
                        <i class="bi bi-arrow-left"></i>
                    </a>
        <div class="container mt-5">
      <h2>Stock Movements</h2>
      <div class="table-responsive">
        <table class="table table-bordered table-striped">
            <thead class="table-dark">
                <tr>
                    <th>ID</th>
                    <th>Product</th>
                    <th>Type</th>
                    <th>Quantity</th>
                    <th>Cost Price</th>
                    <th>Reference</th>
                    <th>Date</th>
                </tr>
            </thead>
            <tbody>
            <% if (movements.length === 0) { %>
                <tr>
                    <td colspan="7" class="text-center">No stock movements found</td>
                </tr>
            <% } else { %>
                <% movements.forEach(m => { %>
                <tr>
                    <td><%= m.id %></td>
                    <td><%= m.product_name %></td>
                    <td>
                        <% if (m.movement_type === 'IN') { %>
                            <span class="badge bg-success">IN</span>
                        <% } else { %>
                            <span class="badge bg-danger">OUT</span>
                        <% } %>
                    </td>
                    <td><%= m.quantity %></td>
                    <td>
                        Rs.<%= Number(m.cost_price).toLocaleString('en-US', { minimumFractionDigits: 2 }) %>
                    </td>
                    <td>
                        <% if (m.reference_type === 'Sales Order') { %>
                            <a href="/sales/orders/view/<%= m.reference_id %>" class="text-dark"><%= m.reference_type %> #<%= m.reference_id %></a>
                        <% } else { %>
                            <a href="/procure/purchase-orders/view/<%= m.reference_id %>" class="text-dark"><%= m.reference_type %> #<%= m.reference_id %></a>
                        <% } %>
                       
                    </td>
                    <td>
                        <%= new Date(m.date).toLocaleString() %>
                    </td>
                </tr>
                <% }) %>
            <% } %>
            </tbody>
        </table>
        </div>
        </div>
    </main>
    </div>
    </div>
</body>
</html>