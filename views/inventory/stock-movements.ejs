<!DOCTYPE html>
<html lang="en">

<head>
    <%- include('../head') %>
        <title>Stock Movements</title>
</head>

<body>
    <div class="container fluid">
        <div class="row position-sticky">
            <%- include('../sidebar') %>
                <main class="col-md-9 col-lg-10 p-2">
                    <a href="javascript:history.back()">
                        <i class="bi bi-arrow-left"></i>
                    </a>
                    <div class="container mt-5">
                        <h2>Stock Movements</h2>
                        <form method="GET" class="card shadow-sm p-3 mb-3">

    <!-- Row 1 -->
    <div class="row g-3">

        <div class="col-md-2">
            <label class="form-label fw-semibold">Date From</label>
            <input type="date"
                   name="from"
                   value="<%= filters.from || '' %>"
                   class="form-control">
        </div>

        <div class="col-md-2">
            <label class="form-label fw-semibold">Date To</label>
            <input type="date"
                   name="to"
                   value="<%= filters.to || '' %>"
                   class="form-control">
        </div>

        <div class="col-md-3">
            <label class="form-label fw-semibold">Category</label>

            <select name="category_id" class="form-select">
                <option value="">All Categories</option>

                <% categories.forEach(c => { %>
                    <option value="<%= c.id %>"
                        <%= filters.category_id == c.id ? "selected" : "" %>>
                        <%= c.name %>
                    </option>
                <% }) %>

            </select>
        </div>

        <div class="col-md-3">
            <label class="form-label fw-semibold">Product</label>

            <select name="product_id" class="form-select">
                <option value="">All Products</option>

                <% products.forEach(p => { %>
                    <option value="<%= p.id %>"
                        <%= filters.product_id == p.id ? "selected" : "" %>>
                        <%= p.name %>
                    </option>
                <% }) %>

            </select>
        </div>

        <div class="col-md-2">
            <label class="form-label fw-semibold">Type</label>

            <select name="type" class="form-select">
                <option value="">All</option>

                <option value="IN"
                    <%= filters.type === "IN" ? "selected" : "" %>>
                    IN
                </option>

                <option value="OUT"
                    <%= filters.type === "OUT" ? "selected" : "" %>>
                    OUT
                </option>
            </select>
        </div>

    </div>

    <!-- Row 2 -->
    <div class="row g-3 mt-1">

        <div class="col-md-3">
            <label class="form-label fw-semibold">Reference</label>

            <select name="reference" class="form-select">
                <option value="">All</option>

                <option value="Sales Order"
                    <%= filters.reference === "Sales Order" ? "selected" : "" %>>
                    Sales
                </option>

                <option value="Purchase Order"
                    <%= filters.reference === "Purchase Order" ? "selected" : "" %>>
                    Purchase
                </option>
            </select>
        </div>

        <!-- Spacer -->
        <div class="col-md-5"></div>

        <!-- Buttons -->
        <div class="col-md-4 d-flex align-items-end gap-2">

            <button class="btn btn-primary flex-fill">
                <i class="bi bi-funnel"></i>
                Apply Filter
            </button>

            <a href="/inventory/stock-movements"
               class="btn btn-outline-secondary flex-fill">
                <i class="bi bi-arrow-counterclockwise"></i>
                Reset
            </a>

        </div>

    </div>

</form>
<!-- Totals Summary -->
<div class="row mb-3">

    <div class="col-md-6">
        <div class="card border-success shadow-sm">
            <div class="card-body">
                <h6 class="text-success mb-1">
                    Total IN Quantity
                </h6>

                <h4 class="fw-bold mb-0">
                    <%= totalIn.toLocaleString() %>
                </h4>
            </div>
        </div>
    </div>

    <div class="col-md-6">
        <div class="card border-danger shadow-sm">
            <div class="card-body">
                <h6 class="text-danger mb-1">
                    Total OUT Quantity
                </h6>

                <h4 class="fw-bold mb-0">
                    <%= totalOut.toLocaleString() %>
                </h4>
            </div>
        </div>
    </div>

</div>
                        <div class="table-responsive">
                            <table class="table">
                                <thead>
                                    <tr>
                                        <th>Sr.</th>
                                        <th>Product</th>
                                        <th>Type</th>
                                        <th>Quantity</th>
                                        <th>Cost Price</th>
                                        <th>Party Name</th>
                                        <th>Reference</th>
                                        <th>Date</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <% if (movements.length===0) { %>
                                        <tr>
                                            <td colspan="7" class="text-center">No stock movements found</td>
                                        </tr>
                                        <% } else { %>
                                            <% movements.forEach((m,idx)=> { %>
                                                <tr>
                                                    <td>
                                                        <%= idx+1 %>
                                                    </td>
                                                    <td>
                                                        <%= m.product_name %>
                                                    </td>
                                                    <td>
                                                        <% if (m.movement_type==='IN' ) { %>
                                                            <span class="badge bg-success">IN</span>
                                                            <% } else { %>
                                                                <span class="badge bg-danger">OUT</span>
                                                                <% } %>
                                                    </td>
                                                    <td>
                                                        <%= m.quantity %>
                                                    </td>
                                                    <td>
                                                        Rs.<%= Number(m.cost_price).toLocaleString('en-US', {
                                                            minimumFractionDigits: 2 }) %>
                                                    </td>
                                                    <td>
                                                        <%= m.party_name %>
                                                    </td>
                                                    <td>
                                                        <% if (m.reference_type ==='Sales Order' ||m.reference_type ==='Sales_Order Edit'  ) { %>
                                                            <a href="/sales/orders/view/<%= m.reference_id %>"
                                                                class="text-dark">
                                                                <%= m.reference_type %> #<%= m.reference_id %>
                                                            </a>
                                                            <% } else { %>
                                                                <a href="/procure/purchase-orders/view/<%= m.reference_id %>"
                                                                    class="text-dark">
                                                                    <%= m.reference_type %> #<%= m.reference_id %>
                                                                </a>
                                                                <% } %>

                                                    </td>
                                                    <td>
                                                        <%= new Date(m.date).toLocaleDateString() %>
                                                    </td>
                                                </tr>
                                                <% }) %>
                                                    <% } %>
                                </tbody>
                            </table>
                        </div>
                    </div>
                </main>
        </div>
    </div>
</body>

</html>