<!DOCTYPE html>
<html lang="en">
<head>
    <%- include('../head') %>
    <title>Document</title>
</head>
<body>
    <div class="container fluid">
    <div class="row position-sticky">
    <%- include('../sidebar') %>
    <main class="col-md-9 col-lg-10 p-4">
       <h2>Edit Product</h2>
        <form method="POST" action="/inventory/products/<%= product.id %>/edit">
            <div class="mb-3">
                <label>Product Name</label>
                <input type="text" class="form-control" value="<%= product.name %>" disabled>
            </div>
            <div class="mb-3">
                <label>Sale Price</label>
                <input type="number" 
                    step="0.01"
                    name="sale_price" 
                    class="form-control"
                    value="<%= product.sale_price %>" 
                    required>
            </div>
            <button type="submit" class="btn btn-primary">
                Update Price
            </button>
        </form>
    </main>
        </div>
    </div>
</body>
</html>