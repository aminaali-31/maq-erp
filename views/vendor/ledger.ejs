<!DOCTYPE html>
<html lang="en">
<head>
    <%- include('../head') %>
    <title>Ledger Details</title>
</head>
<body>
    <%- include('nav') %>
<div class="container mt-4">
    <a href="javascript:history.back()">
                        <i class="bi bi-arrow-left"></i>
                    </a>
    <h2>Vendor Ledger</h2>

    <% if (ledgerEntries.length === 0) { %>
        <p class="text-muted">No ledger entries found.</p>
    <% } else { %>
        <table class="table">
            <thead class="table-light">
                <tr>
                    <th>Date</th>
                    <th>Debit</th>
                    <th>Credit</th>
                    <th>Running Balance</th>
                </tr>
            </thead>
            <tbody>
                <% ledgerEntries.forEach(entry => { %>
                <tr>
                    <td><%= new Date(entry.date).toISOString().split('T')[0] %></td>
                    <td><%= Number(entry.debit).toLocaleString() %></td>
                    <td><%= Number(entry.credit).toLocaleString() %></td>
                    <td><%= Number(entry.running_balance).toLocaleString() %></td>
                </tr>
                <% }) %>
            </tbody>
        </table>
    <% } %>
</div>

</body>
</html>

